# CyberVault Security Platform - Git Ignore Rules
# Comprehensive ignore patterns for security and cleanliness

#######################
# SECURITY SENSITIVE  #
#######################

# Environment variables and secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.key
*.pem
*.crt
*.p12
*.jks
secrets/
credentials/
config/secrets/

# API keys and tokens
*apikey*
*token*
*secret*
*password*
*.credentials

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.backup
*.bak
*.old

#######################
# BUILD ARTIFACTS     #
#######################

# Java/Maven
backend/java/target/
backend/java/.mvn/
*.jar
*.war
*.ear
*.class
*.orig
mvnw
mvnw.cmd
.mvn/wrapper/maven-wrapper.jar

# C/C++ compiled binaries
backend/c/encrypt
backend/cpp/sniffer
*.o
*.so
*.dylib
*.a
*.exe
*.out

# Node.js/React
frontend/node_modules/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/cache
frontend/.yarn/unplugged
frontend/.yarn/build-state.yml
frontend/.yarn/install-state.gz
frontend/build/
frontend/dist/
frontend/.next/
frontend/coverage/

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

