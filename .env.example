# CyberVault Security Platform - Environment Configuration
# Copy this file to .env and configure your settings

#######################
# APPLICATION CONFIG  #
#######################

# Application Environment (development, staging, production)
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080
FRONTEND_PORT=3000
API_BASE_URL=http://localhost:8080/cybervault

#######################
# SECURITY CONFIG     #
#######################

# JWT Configuration (if implementing authentication)
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRATION=3600

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://cybervault.onrender.com
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

#######################
# FILE PROCESSING     #
#######################

# File Upload/Processing Limits
MAX_FILE_SIZE_MB=100
TEMP_DIRECTORY=/tmp/cybervault
UPLOAD_DIRECTORY=./uploads
ENCRYPTED_DIRECTORY=./encrypted
DECRYPTED_DIRECTORY=./decrypted

# Encryption Configuration
DEFAULT_ENCRYPTION_ALGORITHM=AES-256
KEY_LENGTH_MIN=8
KEY_LENGTH_MAX=31

#######################
# NETWORK CONFIG      #
#######################

# Network Analysis Configuration
DEFAULT_NETWORK_INTERFACE=wlan0
MAX_SCAN_DURATION=60
DEFAULT_SCAN_DURATION=10
PACKET_BUFFER_SIZE=65536

#######################
# LOGGING CONFIG      #
#######################

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/cybervault.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=30
ENABLE_REQUEST_LOGGING=true

# Debug Configuration
DEBUG_MODE=false
VERBOSE_LOGGING=false
SQL_DEBUG=false

#######################
# DATABASE CONFIG     #
#######################

# Database Configuration (if needed in future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cybervault
# DB_USERNAME=cybervault_user
# DB_PASSWORD=secure_password_here

#######################
# EXTERNAL SERVICES   #
#######################

# Email Configuration (if implementing notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=true

# Redis Configuration (if implementing session storage)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=redis_password_here

#######################
# MONITORING CONFIG   #
#######################

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
ENABLE_METRICS=true
ENABLE_ACTUATOR=true

# Performance Monitoring
ENABLE_PROFILING=false
MEMORY_THRESHOLD_MB=512
CPU_THRESHOLD_PERCENT=80

#######################
# DEPLOYMENT CONFIG   #
#######################

# Docker Configuration
DOCKER_IMAGE_NAME=cybervault
DOCKER_TAG=latest
CONTAINER_NAME=cybervault-app

# Build Configuration
BUILD_TIMESTAMP=
BUILD_VERSION=2.0.0
BUILD_ENVIRONMENT=development

#######################
# DEVELOPMENT CONFIG  #
#######################

# Development Tools
HOT_RELOAD=true
WEBPACK_DEVTOOL=eval-source-map
ENABLE_DEVTOOLS=true

# Testing Configuration
TEST_TIMEOUT=30000
COVERAGE_THRESHOLD=70
MOCK_EXTERNAL_SERVICES=true

#######################
# SECURITY HEADERS    #
#######################

# Security Headers Configuration
ENABLE_HELMET=true
FORCE_HTTPS=false
ENABLE_HSTS=true
ENABLE_CONTENT_SECURITY_POLICY=true

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_TIMEOUT=1800
SECURE_COOKIES=false

#######################
# BACKUP CONFIG       #
#######################

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_INTERVAL=24

#######################
# NOTIFICATION CONFIG #
#######################

# Notification Settings
ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=admin@cybervault.com
SLACK_WEBHOOK_URL=

#######################
# CUSTOM CONFIG       #
#######################

# Custom Application Settings
BRAND_NAME=CyberVault
ORGANIZATION_NAME=CyberVault Security
COPYRIGHT_YEAR=2025
SUPPORT_EMAIL=support@cybervault.com
DOCUMENTATION_URL=https://docs.cybervault.com

# Feature Flags
ENABLE_ENCRYPTION=true
ENABLE_DECRYPTION=true
ENABLE_NETWORK_SCAN=true
ENABLE_FILE_UPLOAD=true
ENABLE_BATCH_OPERATIONS=false

#######################
# NOTES               #
#######################

# IMPORTANT SECURITY NOTES:
# 1. Change all secret keys and passwords in production
# 2. Use environment-specific .env files (.env.production, .env.staging)
# 3. Never commit .env files to version control
# 4. Regularly rotate secrets and passwords
# 5. Use proper secret management tools in production
# 6. Enable HTTPS in production (FORCE_HTTPS=true)
# 7. Set SECURE_COOKIES=true in production
# 8. Review and update CORS settings for production domains